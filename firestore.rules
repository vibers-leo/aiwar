rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - root level
    match /users/{userId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow write only to own document
      allow write: if isOwner(userId) && 
                      request.resource.data.userId == userId;
      
      // Profile subcollection
      match /profile/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
      
      // Inventory subcollection
      match /inventory/{cardId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // Decks subcollection
      match /decks/{deckId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // Achievements subcollection
      match /achievements/{achievementId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
    
    // Support tickets - root level (admin + owner access)
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && 
                     (resource.data.userId == request.auth.uid || 
                      request.auth.token.email == 'juuuno@naver.com');
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.token.email == 'juuuno@naver.com';
    }
    
    // Leaderboard - read-only for all authenticated users
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if false; // Managed by Cloud Functions only
    }
    
    // Global settings - read-only
    match /settings/{document=**} {
      allow read: if true;
      allow write: if false; // Admin only via console
    }
  }
}
