rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - root level
    match /users/{userId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow write only to own document
      allow write: if isOwner(userId);
      
      // Profile subcollection (users/{userId}/profile/data)
      match /profile/{document=**} {
        allow read: if isAuthenticated(); // [MODIFIED] Allow all authenticated users to read profiles
        allow write: if isOwner(userId);
      }
      
      // Generic Data Subcollection (Singleton docs)
      match /data/{document=**} {
        allow read, write: if isOwner(userId);
      }

      // Progress Subcollection
      match /progress/{document=**} {
        allow read, write: if isOwner(userId);
      }

      // Factions Subcollection
      match /factions/{document=**} {
        allow read, write: if isOwner(userId);
      }

      // Friends Subcollection
      match /friends/{friendId} {
        // Owner has full access, and any user can read their own entry in another user's list
        allow read: if isOwner(userId) || (isAuthenticated() && friendId == request.auth.uid);
        
        // 1. Owner can write anything
        allow write: if isOwner(userId);
        
        // 2. Cross-user access (initiated by the friendId user)
        // Create: Allow sending a friend request (creating a 'pending_received' status doc in target's list)
        allow create: if isAuthenticated() && 
                         friendId == request.auth.uid && 
                         request.resource.data.status == 'pending_received';
                         
        // Update: Allow accepting a request (updating status to 'accepted' in sender's list)
        allow update: if isAuthenticated() && 
                         friendId == request.auth.uid && 
                         resource.data.status == 'pending_sent' &&
                         request.resource.data.status == 'accepted';
                         
        // Delete: Allow canceling/removing oneself from someone else's list
        allow delete: if isAuthenticated() && friendId == request.auth.uid;
      }

      // Chat Collections
      match /chatRooms/{roomId} {
        allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
        allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
        allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

        match /messages/{messageId} {
          allow read: if isAuthenticated() && 
                         request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
          allow create: if isAuthenticated() && 
                          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants &&
                          request.resource.data.senderId == request.auth.uid;
        }
      }
      
      match /inventory/{cardId} {
        allow read, write: if isOwner(userId);
      }
      
      match /decks/{deckId} {
        allow read, write: if isOwner(userId);
      }
      
      match /subscriptions/{subscriptionId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Support tickets
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && 
                     (resource.data.userId == request.auth.uid || 
                      request.auth.token.email == 'juuuno@naver.com');
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.token.email == 'juuuno@naver.com';
    }
    
    // Leaderboard
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Nicknames
    match /nicknames/{nickname} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Settings
    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
