{
    "rules": {
        "users": {
            "$userId": {
                ".read": "$userId === auth.uid",
                ".write": "$userId === auth.uid",
                ".indexOn": ["level", "totalPower", "updatedAt"]
            }
        },
        "leaderboard": {
            "global": {
                ".read": true,
                "$userId": {
                    ".write": "$userId === auth.uid",
                    ".validate": "newData.hasChildren(['displayName', 'level', 'totalPower', 'winRate', 'userId', 'updatedAt'])"
                },
                ".indexOn": ["level", "totalPower", "winRate"]
            }
        },
        "minigame": {
            "cardClash": {
                "queue": {
                    ".read": "auth != null",
                    "$userId": {
                        ".write": "$userId === auth.uid || !data.exists()",
                        ".validate": "newData.hasChildren(['userId', 'mode', 'betAmount', 'hand', 'timestamp'])"
                    }
                },
                "activeGames": {
                    "$gameId": {
                        ".read": "auth != null && (data.child('player1/userId').val() === auth.uid || data.child('player2/userId').val() === auth.uid)",
                        ".write": "auth != null && (!data.exists() || data.child('player1/userId').val() === auth.uid || data.child('player2/userId').val() === auth.uid)"
                    }
                },
                "results": {
                    "$userId": {
                        ".read": "$userId === auth.uid",
                        ".write": "$userId === auth.uid"
                    }
                }
            }
        },
        "chat": {
            ".read": "auth != null",
            "$chatId": {
                ".write": "auth != null",
                ".validate": "newData.hasChildren(['userId', 'displayName', 'message', 'timestamp']) && newData.child('message').val().length <= 500"
            }
        },
        "waitingRooms": {
            ".read": "auth != null",
            "$code": {
                ".write": "auth != null && (!data.exists() || data.child('hostId').val() == auth.uid || newData.child('status').val() == 'matched')",
                ".validate": "newData.hasChildren(['hostId', 'status'])",
                "status": {
                    ".validate": "newData.val() == 'waiting' || newData.val() == 'matched'"
                }
            }
        },
        "battles": {
            ".read": "auth != null",
            "$roomId": {
                ".write": "auth != null && (!data.exists() || data.child('player1/playerId').val() == auth.uid || data.child('player2/playerId').val() == auth.uid)",
                ".validate": "!data.exists() || data.child('finished').val() == false",
                "player1": {
                    ".write": "auth != null && (newData.child('playerId').val() == auth.uid || data.child('playerId').val() == auth.uid)",
                    "ready": {
                        ".validate": "newData.isBoolean()"
                    },
                    "selectedCards": {
                        ".validate": "newData.exists()"
                    }
                },
                "player2": {
                    ".write": "auth != null && (newData.child('playerId').val() == auth.uid || data.child('playerId').val() == auth.uid)",
                    "ready": {
                        ".validate": "newData.isBoolean()"
                    },
                    "selectedCards": {
                        ".validate": "newData.exists()"
                    }
                }
            }
        },
        "matchmaking": {
            ".read": "auth != null",
            "$mode": {
                "$uid": {
                    ".write": "auth != null && (auth.uid == $uid)",
                    ".validate": "newData.hasChildren(['playerId', 'status'])"
                }
            }
        },
        "minigame_rooms": {
            ".read": "auth != null",
            "$roomId": {
                ".write": "auth != null && (!data.exists() || data.child('hostId').val() == auth.uid || data.child('guestId').val() == auth.uid)",
                ".indexOn": ["status", "createdAt"]
            }
        },
        "clash_rooms": {
            ".read": "auth != null",
            "$roomId": {
                ".write": "auth != null && (!data.exists() || data.child('hostId').val() == auth.uid || data.child('guestId').val() == auth.uid)",
                ".indexOn": ["status", "mode", "createdAt"]
            }
        },
        "clash_chats": {
            "$roomId": {
                ".read": "auth != null",
                ".write": "auth != null",
                "$messageId": {
                    ".validate": "newData.hasChildren(['senderId', 'senderName', 'message', 'timestamp']) && newData.child('message').val().length <= 100"
                }
            }
        }
    }
}